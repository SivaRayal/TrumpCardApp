{
  "expo": {
    "name": "Trump-Card",
    "slug": "TrumpCardApp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/appicon.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#04040A",
    "splash": {
      "backgroundColor": "#04040A"
    },
    "ios": {
      "supportsTablet": false,
      "infoPlist": {
        "NSFaceIDUsageDescription": "TrumpCard uses biometrics to securely authenticate you.",
        "NSPhotoLibraryAddUsageDescription": "TrumpCard needs access to save wallpapers to your gallery."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#04040A"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO"
      ],
      "package": "com.sivarayal.TrumpCardApp"
    },
    "web": {
      "favicon": "./assets/appicon.png"
    },
    "plugins": [
      "expo-sqlite",
      "expo-secure-store",
      "expo-sharing",
      "expo-font",
      "expo-local-authentication",
      [
        "expo-media-library",
        {
          "photosPermission": "Allow TrumpCard to save wallpapers to your photo library.",
          "savePhotosPermission": "Allow TrumpCard to save wallpapers to your photo library."
        }
      ]
    ],
    "assets": [
      "./src/assets/data"
    ],
    "extra": {
      "eas": {
        "projectId": "fcd91d3a-a9d7-4ffd-a2fd-1d334636daec"
      }
    }
  }
}
